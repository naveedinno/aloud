{
  "name": "aloud",
  "version": "0.1.0",
  "description": "A private local Mac app that reads selected and pasted text aloud.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "npm run clean:dist && tsc",
    "build:macos-app": "npm run build && bash scripts/build-macos-app.sh",
    "build:macos-dmg": "npm run build:macos-app && bash scripts/build-macos-dmg.sh",
    "clean": "bash scripts/clean.sh",
    "clean:dist": "bash scripts/clean.sh --dist-only",
    "dev": "npm run build && npm run start",
    "install:macos-service": "npm run build && bash scripts/install-macos-service.sh",
    "setup:aloud": "bash scripts/setup-aloud.sh",
    "start": "bash scripts/run-aloud.sh",
    "test": "npm run build && node --test test/*.test.mjs",
    "test:packaging": "node --test test/macos-service-script.test.mjs test/macos-packaging-clean-room.test.mjs",
    "uninstall:macos-service": "bash scripts/uninstall-macos-service.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
